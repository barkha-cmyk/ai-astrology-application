# AI Astrologer Environment Variables
# Add your actual API keys here for full functionality

# ============================================
# OpenAI API Key (REQUIRED for AI features)
# ============================================
# Get your key from: https://platform.openai.com/api-keys
# Example: OPENAI_API_KEY=sk-proj-abc123xyz789...
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ============================================
# Supabase Configuration (Optional - for database features)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_key

# ============================================
# Daily.co Configuration (Optional - for video calls)
# ============================================
DAILY_API_KEY=your_daily_api_key
NEXT_PUBLIC_DAILY_DOMAIN=your_daily_domain

# ============================================
# Socket.io Configuration (Optional - for real-time chat)
# ============================================
NEXT_PUBLIC_SOCKET_URL=http://localhost:8080

# ============================================
# Notes:
# ============================================
# - The application will work without API keys, but AI features will be limited
# - AI chatbot requires OpenAI API key
# - Database features require Supabase setup
# - Video calls require Daily.co account
# - All other features work independently!
 
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=openai/gpt-4o-mini
NEXT_PUBLIC_APP_URL=http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:5001

# ============================================
# ElevenLabs TTS (Pro voice for avatar)
# ============================================
# Get your key from: https://elevenlabs.io/
# NOTE: Keep secrets out of git and never share them publicly.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
